# ============================================================================
# Werewolf AI Game - Environment Configuration
# ============================================================================
#
# 快速配置指南（3步开始游戏）：
# 1. 复制此文件为 .env
# 2. 填写 OPENAI_API_KEY=sk-your-key（或其他provider）
# 3. docker compose up -d --build
#
# 高级配置：
# - AI分析：配置 ANALYSIS_PROVIDER 使用更强模型（推荐GPT-4）
# - 多模型：配置不同provider给不同玩家
# - 性能：启用分析缓存、调整token限制
#
# ============================================================================

# ============================================================================
# 基础配置
# ============================================================================
DEBUG=false
LOG_LEVEL=INFO
LANGUAGE=zh                    # 游戏语言: zh(中文) | en(English)

# ============================================================================
# AI 对局分析配置（独立于游戏AI）
# ============================================================================
# 说明：
# - 分析需要更强推理能力，建议使用 GPT-4、Claude 等高级模型
# - ANALYSIS_PROVIDER 为空时使用 default provider
# - 分析结果可缓存，避免重复计算

ANALYSIS_PROVIDER=              # 指定provider名称(openai/anthropic/deepseek等)，空则用default
ANALYSIS_MODEL=gpt-4o           # 推荐: gpt-4o, gpt-4-turbo, claude-3-sonnet
ANALYSIS_MAX_TOKENS=4000        # 分析需要更长输出
ANALYSIS_TEMPERATURE=0.7
ANALYSIS_MODE=comprehensive     # 分析模式: comprehensive(详尽) | quick(快速) | custom(自定义)
ANALYSIS_LANGUAGE=auto          # 分析语言: auto(跟随游戏) | zh | en
ANALYSIS_CACHE_ENABLED=true    # 是否启用分析缓存（避免重复分析同一局）

# ============================================================================
# 默认游戏AI配置
# ============================================================================
# 说明：
# - 当玩家未指定专属provider时使用此配置
# - LLM_USE_MOCK=true 时不调用真实API（测试用）

LLM_MODEL=gpt-4o-mini
LLM_MAX_RETRIES=2
LLM_USE_MOCK=false              # 强制Mock模式（无API调用）

# ============================================================================
# 前端配置
# ============================================================================
# Docker部署：保持空字符串（Nginx反代）
VITE_API_URL=
# 本地开发：设置后端地址
# VITE_API_URL=http://localhost:8082

# ============================================================================
# 命名 Provider 池（按需启用）
# ============================================================================
# 规则：
# - 只要 *_API_KEY 非空，该provider就会启用
# - 名称会自动转为小写（OPENAI -> openai）
# - BASE_URL 留空使用SDK默认地址

# --- OpenAI（推荐用于default） ---
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=2
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=500

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=             # 需OpenAI兼容网关
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_MAX_RETRIES=2
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=500

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=500

# --- Moonshot (Kimi) ---
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k
MOONSHOT_MAX_RETRIES=2
MOONSHOT_TEMPERATURE=0.7
MOONSHOT_MAX_TOKENS=500

# --- Qwen (通义千问) ---
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo
QWEN_MAX_RETRIES=2
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=500

# --- GLM (智谱) ---
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash
GLM_MAX_RETRIES=2
GLM_TEMPERATURE=0.7
GLM_MAX_TOKENS=500

# --- Doubao (豆包/火山方舟) ---
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODEL=doubao-pro-4k
DOUBAO_MAX_RETRIES=2
DOUBAO_TEMPERATURE=0.7
DOUBAO_MAX_TOKENS=500

# --- MiniMax ---
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL=abab6.5s-chat
MINIMAX_MAX_RETRIES=2
MINIMAX_TEMPERATURE=0.7
MINIMAX_MAX_TOKENS=500

# ============================================================================
# 自定义 Provider（可选，最多9个）
# ============================================================================
AI_PROVIDER_1_NAME=
AI_PROVIDER_1_API_KEY=
AI_PROVIDER_1_BASE_URL=
AI_PROVIDER_1_MODEL=
AI_PROVIDER_1_MAX_RETRIES=2
AI_PROVIDER_1_TEMPERATURE=0.7
AI_PROVIDER_1_MAX_TOKENS=500

AI_PROVIDER_2_NAME=
AI_PROVIDER_2_API_KEY=
AI_PROVIDER_2_BASE_URL=
AI_PROVIDER_2_MODEL=
AI_PROVIDER_2_MAX_RETRIES=2
AI_PROVIDER_2_TEMPERATURE=0.7
AI_PROVIDER_2_MAX_TOKENS=500

# ============================================================================
# 座位到 Provider 映射（可选）
# ============================================================================
# 配置优先级(从高到低):
# 1. AI_PLAYER_{seat}_PROVIDER    - 单独指定(最高)
# 2. AI_PLAYER_MAPPING            - JSON批量映射
# 3. AI_PLAYER_{seat}_API_KEY     - 专属配置自动映射
# 4. default provider             - OPENAI_* 兜底(最低)
#
# 示例：
# OPENAI_API_KEY=sk-xxx                      # 大部分玩家用这个
# ANTHROPIC_API_KEY=sk-ant-xxx               # 配置Claude
# AI_PLAYER_3_PROVIDER=anthropic             # 3号玩家用Claude
# AI_PLAYER_5_API_KEY=sk-deepseek-xxx        # 5号玩家独立配置
# AI_PLAYER_5_BASE_URL=https://api.deepseek.com/v1
# AI_PLAYER_MAPPING={"4":"anthropic"}        # 4号也用Claude

AI_PLAYER_MAPPING=

# --- 单独指定provider ---
AI_PLAYER_1_PROVIDER=
AI_PLAYER_2_PROVIDER=
AI_PLAYER_3_PROVIDER=
AI_PLAYER_4_PROVIDER=
AI_PLAYER_5_PROVIDER=
AI_PLAYER_6_PROVIDER=
AI_PLAYER_7_PROVIDER=
AI_PLAYER_8_PROVIDER=
AI_PLAYER_9_PROVIDER=

# ============================================================================
# 座位独立配置（座位2-9，高级用法）
# ============================================================================
# 说明：
# - 配置 AI_PLAYER_{seat}_API_KEY 会自动创建专属provider: player_{seat}
# - 适用场景：某玩家需要完全独立的API配置

AI_PLAYER_2_NAME=
AI_PLAYER_2_API_KEY=
AI_PLAYER_2_BASE_URL=
AI_PLAYER_2_MODEL=gpt-4o-mini
AI_PLAYER_2_MAX_RETRIES=2
AI_PLAYER_2_TEMPERATURE=0.7
AI_PLAYER_2_MAX_TOKENS=500

AI_PLAYER_3_NAME=
AI_PLAYER_3_API_KEY=
AI_PLAYER_3_BASE_URL=
AI_PLAYER_3_MODEL=gpt-4o-mini
AI_PLAYER_3_MAX_RETRIES=2
AI_PLAYER_3_TEMPERATURE=0.7
AI_PLAYER_3_MAX_TOKENS=500

AI_PLAYER_4_NAME=
AI_PLAYER_4_API_KEY=
AI_PLAYER_4_BASE_URL=
AI_PLAYER_4_MODEL=gpt-4o-mini
AI_PLAYER_4_MAX_RETRIES=2
AI_PLAYER_4_TEMPERATURE=0.7
AI_PLAYER_4_MAX_TOKENS=500

AI_PLAYER_5_NAME=
AI_PLAYER_5_API_KEY=
AI_PLAYER_5_BASE_URL=
AI_PLAYER_5_MODEL=gpt-4o-mini
AI_PLAYER_5_MAX_RETRIES=2
AI_PLAYER_5_TEMPERATURE=0.7
AI_PLAYER_5_MAX_TOKENS=500

AI_PLAYER_6_NAME=
AI_PLAYER_6_API_KEY=
AI_PLAYER_6_BASE_URL=
AI_PLAYER_6_MODEL=gpt-4o-mini
AI_PLAYER_6_MAX_RETRIES=2
AI_PLAYER_6_TEMPERATURE=0.7
AI_PLAYER_6_MAX_TOKENS=500

AI_PLAYER_7_NAME=
AI_PLAYER_7_API_KEY=
AI_PLAYER_7_BASE_URL=
AI_PLAYER_7_MODEL=gpt-4o-mini
AI_PLAYER_7_MAX_RETRIES=2
AI_PLAYER_7_TEMPERATURE=0.7
AI_PLAYER_7_MAX_TOKENS=500

AI_PLAYER_8_NAME=
AI_PLAYER_8_API_KEY=
AI_PLAYER_8_BASE_URL=
AI_PLAYER_8_MODEL=gpt-4o-mini
AI_PLAYER_8_MAX_RETRIES=2
AI_PLAYER_8_TEMPERATURE=0.7
AI_PLAYER_8_MAX_TOKENS=500

AI_PLAYER_9_NAME=
AI_PLAYER_9_API_KEY=
AI_PLAYER_9_BASE_URL=
AI_PLAYER_9_MODEL=gpt-4o-mini
AI_PLAYER_9_MAX_RETRIES=2
AI_PLAYER_9_TEMPERATURE=0.7
AI_PLAYER_9_MAX_TOKENS=500

# ============================================================================
# 结束配置
# ============================================================================
