# ============================================================================
# Werewolf AI Game - 环境配置模板
# ============================================================================
#
# 快速配置指南（3步开始使用）：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填写 OPENAI_API_KEY（至少需要这一项）
# 3. 重启后端服务：docker compose up -d --build
#
# 📁 文件位置：项目根目录/.env
# 📋 验证配置：cd backend && python verify_config.py
#
# ============================================================================

# ============================================================
# 第1层：基础配置（必需）
# ============================================================
# OpenAI API密钥（必需）
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI Base URL（可选，用于代理或兼容服务）
# 默认：https://api.openai.com/v1
# OPENAI_BASE_URL=

# 默认AI模型（用于游戏中的AI玩家）
# 可选值：gpt-4o-mini, gpt-4o, gpt-3.5-turbo
LLM_MODEL=gpt-4o-mini

# AI请求重试次数
LLM_MAX_RETRIES=2

# 使用Mock模式（开发测试用，不调用真实API）
LLM_USE_MOCK=false

# ============================================================
# 第2层：AI对局分析配置（独立配置）
# ============================================================
# 专用分析provider（可选，不设置则使用OPENAI配置）
# 可选值：openai, deepseek, gemini, anthropic
# 留空则使用默认OpenAI配置
ANALYSIS_PROVIDER=

# 分析专用模型（推荐使用高级模型）
# OpenAI推荐：gpt-4o, gpt-4-turbo
# Deepseek推荐：deepseek-chat
ANALYSIS_MODEL=gpt-4o

# 分析模式
# - comprehensive: 详细分析（默认，3-5分钟）
# - quick: 快速分析（1-2分钟）
# - custom: 自定义模式（需要修改代码）
ANALYSIS_MODE=comprehensive

# 分析语言
# - auto: 自动检测（根据游戏语言）
# - zh: 强制中文
# - en: 强制英文
ANALYSIS_LANGUAGE=auto

# 分析结果缓存
# 开启后，相同game_id+mode+language的分析结果会被缓存
# 避免重复计算，节省API成本
ANALYSIS_CACHE_ENABLED=true

# 分析生成参数
ANALYSIS_MAX_TOKENS=4000
ANALYSIS_TEMPERATURE=0.7

# ============================================================
# 第3层：游戏AI个性配置（可选）
# ============================================================
# 为不同座位号配置不同的AI provider
# 格式：PLAYER_N_PROVIDER=provider_name（N为座位号1-9）
#
# 示例：让1号玩家使用deepseek，2号使用OpenAI
# PLAYER_1_PROVIDER=deepseek
# PLAYER_2_PROVIDER=openai

# ============================================================
# 第4层：多Provider池配置（高级）
# ============================================================
# 配置多个AI服务商，可按座位号分配

# --- Deepseek配置 ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MAX_RETRIES=2
# DEEPSEEK_TEMPERATURE=0.7
# DEEPSEEK_MAX_TOKENS=500

# --- Google Gemini配置 ---
# GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1
# GEMINI_MODEL=gemini-pro
# GEMINI_MAX_RETRIES=2
# GEMINI_TEMPERATURE=0.7
# GEMINI_MAX_TOKENS=500

# --- Anthropic Claude配置 ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=claude-3-sonnet-20240229
# ANTHROPIC_MAX_RETRIES=2
# ANTHROPIC_TEMPERATURE=0.7
# ANTHROPIC_MAX_TOKENS=500

# --- 自定义OpenAI兼容服务 ---
# CUSTOM_API_KEY=
# CUSTOM_BASE_URL=
# CUSTOM_MODEL=
# CUSTOM_MAX_RETRIES=2
# CUSTOM_TEMPERATURE=0.7
# CUSTOM_MAX_TOKENS=500

# ============================================================
# 第5层：座位映射配置（高级）
# ============================================================
# 将特定座位号映射到特定provider
# 用于实现多样化AI对战（不同AI服务商的AI玩家对战）
#
# 格式：PLAYER_MAPPINGS={"1":"deepseek","2":"openai","3":"gemini"}
# PLAYER_MAPPINGS=

# ============================================================
# 应用设置
# ============================================================
# 调试模式
DEBUG=false

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# ============================================================
# 配置验证
# ============================================================
# 配置完成后，运行以下命令验证配置是否正确：
#   cd backend && python verify_config.py
#
# 验证工具会检查：
# ✓ Provider配置是否有效
# ✓ API密钥是否设置
# ✓ 分析配置是否完整
#
# ============================================================
# 最小配置示例（仅OpenAI）
# ============================================================
# OPENAI_API_KEY=sk-your-key-here
#
# 这是最简配置，足以启动游戏和分析功能
# 其他配置项使用默认值
#
# ⚠️ 注意：.env文件应位于项目根目录
# ============================================================
