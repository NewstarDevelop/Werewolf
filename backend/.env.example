# ============================================
# Werewolf AI Game - Environment Configuration
# ============================================

# ==========================================
# Default LLM Configuration
# ==========================================
# This is the default provider used when no specific provider is configured
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_MAX_RETRIES=2
LLM_USE_MOCK=false

# ==========================================
# Application Settings
# ==========================================
DEBUG=false
LOG_LEVEL=INFO

# ==========================================
# Multi-Provider Configuration
# ==========================================
# You can configure multiple AI providers and assign them to different players
# Each provider uses the OpenAI-compatible API format

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=500

# --- Anthropic (Claude) ---
# Note: Requires OpenAI-compatible proxy or adapter
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# --- DeepSeek ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Moonshot (Kimi) ---
MOONSHOT_API_KEY=your-moonshot-api-key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k

# --- Qwen (Alibaba Tongyi) ---
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# --- GLM (Zhipu AI) ---
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

# --- Doubao (ByteDance) ---
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-4k

# --- MiniMax ---
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# ==========================================
# Custom Providers
# ==========================================
# You can add up to 9 custom providers with any OpenAI-compatible API

# AI_PROVIDER_1_NAME=my-custom-provider
# AI_PROVIDER_1_API_KEY=your-api-key
# AI_PROVIDER_1_BASE_URL=https://api.example.com/v1
# AI_PROVIDER_1_MODEL=custom-model
# AI_PROVIDER_1_TEMPERATURE=0.7
# AI_PROVIDER_1_MAX_TOKENS=500

# AI_PROVIDER_2_NAME=another-provider
# AI_PROVIDER_2_API_KEY=your-api-key
# AI_PROVIDER_2_BASE_URL=https://api.another.com/v1
# AI_PROVIDER_2_MODEL=another-model

# ==========================================
# Player to Provider Mapping
# ==========================================
# Assign specific AI providers to specific player seats (2-9, seat 1 is human)
# You can use either JSON format or individual variables

# Option 1: JSON format (all at once)
# AI_PLAYER_MAPPING={"2":"openai","3":"deepseek","4":"moonshot","5":"qwen","6":"glm","7":"anthropic","8":"doubao","9":"minimax"}

# Option 2: Individual variables (override JSON)
# AI_PLAYER_2_PROVIDER=openai
# AI_PLAYER_3_PROVIDER=deepseek
# AI_PLAYER_4_PROVIDER=moonshot
# AI_PLAYER_5_PROVIDER=qwen
# AI_PLAYER_6_PROVIDER=glm
# AI_PLAYER_7_PROVIDER=anthropic
# AI_PLAYER_8_PROVIDER=doubao
# AI_PLAYER_9_PROVIDER=minimax

# ==========================================
# Example Configurations
# ==========================================

# Example 1: All players use OpenAI
# Just set OPENAI_API_KEY and leave other providers empty

# Example 2: Mix of providers
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# MOONSHOT_API_KEY=sk-xxx
# AI_PLAYER_MAPPING={"2":"openai","3":"openai","4":"deepseek","5":"deepseek","6":"moonshot","7":"moonshot","8":"openai","9":"deepseek"}

# Example 3: Different models compete
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o
# AI_PROVIDER_1_NAME=gpt4-mini
# AI_PROVIDER_1_API_KEY=sk-xxx
# AI_PROVIDER_1_MODEL=gpt-4o-mini
# AI_PLAYER_MAPPING={"2":"openai","3":"gpt4-mini","4":"openai","5":"gpt4-mini","6":"openai","7":"gpt4-mini","8":"openai","9":"gpt4-mini"}
