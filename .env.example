# ============================================
# Werewolf - Docker Compose 环境变量示例
# ============================================
#
# 用法（与 docker-compose.yml 同级）：
# 1) 复制本文件为 .env
# 2) 填入你的 API Key
# 3) docker compose up -d --build
#
# 注意：
# - 本文件用于 Docker Compose 变量替换与注入容器环境变量
# - backend/.env 仅用于“本地直接运行后端”（非 docker compose）场景
#

# ============================================
# 应用基础配置
# ============================================
DEBUG=false
LOG_LEVEL=INFO

# 是否强制使用 Mock（不调用真实 API）
LLM_USE_MOCK=false

# 默认 LLM 配置（当某个座位未命中专属配置/映射时使用）
# LLM_MODEL一定要修改为想要使用的模型
LLM_MODEL=gpt-4o-mini 
LLM_MAX_RETRIES=2

# ============================================
# 命名 Provider（推荐：1 个 Provider + 多座位映射）
# ============================================
# 说明：
# - Provider 名称在代码中会转换为小写（openai / deepseek / anthropic ...）
# - 仅当 *_API_KEY 非空时，该 provider 才会被加载启用

# OpenAI（default provider 使用 OPENAI_API_KEY + OPENAI_BASE_URL + LLM_MODEL）
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Anthropic（Claude；需 OpenAI 兼容网关/代理，才能通过 OpenAI SDK 调用）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# DeepSeek（OpenAI 兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Moonshot（Kimi，OpenAI 兼容）
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k

# Qwen（DashScope OpenAI 兼容）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# GLM（智谱 OpenAI 兼容）
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

# Doubao（火山方舟 OpenAI 兼容；按需填写 BASE_URL）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODEL=doubao-pro-4k

# MiniMax（按需填写 BASE_URL）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL=abab6.5s-chat

# ============================================
# 自定义 Provider（可选：AI_PROVIDER_1/2...）
# ============================================
AI_PROVIDER_1_NAME=
AI_PROVIDER_1_API_KEY=
AI_PROVIDER_1_BASE_URL=
AI_PROVIDER_1_MODEL=

AI_PROVIDER_2_NAME=
AI_PROVIDER_2_API_KEY=
AI_PROVIDER_2_BASE_URL=
AI_PROVIDER_2_MODEL=

# ============================================
# 座位到 Provider 的映射（可选，优先级最高）
# ============================================
# 优先级：AI_PLAYER_{seat}_PROVIDER > AI_PLAYER_MAPPING(JSON) > AI_PLAYER_{seat}_*（每座位独立）

# JSON 一次性映射（示例）
# AI_PLAYER_MAPPING={"3":"deepseek","7":"anthropic"}
AI_PLAYER_MAPPING=

# 单独映射（示例：让 3 号/7 号走 deepseek；其余走 default）
AI_PLAYER_2_PROVIDER=
AI_PLAYER_3_PROVIDER=
AI_PLAYER_4_PROVIDER=
AI_PLAYER_5_PROVIDER=
AI_PLAYER_6_PROVIDER=
AI_PLAYER_7_PROVIDER=
AI_PLAYER_8_PROVIDER=
AI_PLAYER_9_PROVIDER=

# ============================================
# 每座位独立配置（座位 2-9，可选）
# ============================================
# 说明：
# - 只要该座位的 NAME 或 API_KEY 任一不为空，就会创建 provider：player_{seat}
# - 该座位会自动映射到 player_{seat}
# - 如果 API_KEY 为空，则会回退使用 OPENAI_API_KEY（不推荐用于多家 Key 混用）

AI_PLAYER_2_NAME=
AI_PLAYER_2_API_KEY=
AI_PLAYER_2_BASE_URL=
AI_PLAYER_2_MODEL=gpt-4o-mini
AI_PLAYER_2_TEMPERATURE=0.7
AI_PLAYER_2_MAX_RETRIES=2
AI_PLAYER_2_MAX_TOKENS=500

AI_PLAYER_3_NAME=
AI_PLAYER_3_API_KEY=
AI_PLAYER_3_BASE_URL=
AI_PLAYER_3_MODEL=gpt-4o-mini
AI_PLAYER_3_TEMPERATURE=0.7
AI_PLAYER_3_MAX_RETRIES=2
AI_PLAYER_3_MAX_TOKENS=500

AI_PLAYER_4_NAME=
AI_PLAYER_4_API_KEY=
AI_PLAYER_4_BASE_URL=
AI_PLAYER_4_MODEL=gpt-4o-mini
AI_PLAYER_4_TEMPERATURE=0.7
AI_PLAYER_4_MAX_RETRIES=2
AI_PLAYER_4_MAX_TOKENS=500

AI_PLAYER_5_NAME=
AI_PLAYER_5_API_KEY=
AI_PLAYER_5_BASE_URL=
AI_PLAYER_5_MODEL=gpt-4o-mini
AI_PLAYER_5_TEMPERATURE=0.7
AI_PLAYER_5_MAX_RETRIES=2
AI_PLAYER_5_MAX_TOKENS=500

AI_PLAYER_6_NAME=
AI_PLAYER_6_API_KEY=
AI_PLAYER_6_BASE_URL=
AI_PLAYER_6_MODEL=gpt-4o-mini
AI_PLAYER_6_TEMPERATURE=0.7
AI_PLAYER_6_MAX_RETRIES=2
AI_PLAYER_6_MAX_TOKENS=500

AI_PLAYER_7_NAME=
AI_PLAYER_7_API_KEY=
AI_PLAYER_7_BASE_URL=
AI_PLAYER_7_MODEL=gpt-4o-mini
AI_PLAYER_7_TEMPERATURE=0.7
AI_PLAYER_7_MAX_RETRIES=2
AI_PLAYER_7_MAX_TOKENS=500

AI_PLAYER_8_NAME=
AI_PLAYER_8_API_KEY=
AI_PLAYER_8_BASE_URL=
AI_PLAYER_8_MODEL=gpt-4o-mini
AI_PLAYER_8_TEMPERATURE=0.7
AI_PLAYER_8_MAX_RETRIES=2
AI_PLAYER_8_MAX_TOKENS=500

AI_PLAYER_9_NAME=
AI_PLAYER_9_API_KEY=
AI_PLAYER_9_BASE_URL=
AI_PLAYER_9_MODEL=gpt-4o-mini
AI_PLAYER_9_TEMPERATURE=0.7
AI_PLAYER_9_MAX_RETRIES=2
AI_PLAYER_9_MAX_TOKENS=500
