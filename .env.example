# ============================================================================
# Werewolf - 标准 .env.example（用于 docker compose / 本地开发）
# ============================================================================
#
# 用法（与 docker-compose.yml 同级）：
# 1) 复制本文件为 .env
# 2) 填入你的 API Key（不要提交到 git）
# 3) docker compose up -d --build
#
# 说明：
# - Docker 部署：前端通过 Nginx 反代到 /api（保持 VITE_API_URL 为空字符串即可）
# - 本地前端开发：设置 VITE_API_URL 指向后端（docker-compose 后端默认端口 8082）
# - 后端支持多 Provider、多座位映射；只要 *_API_KEY 非空，该 provider 才会启用
#

# ============================================================================
# 基础配置（backend）
# ============================================================================
DEBUG=false
LOG_LEVEL=INFO

# 语言设置 (zh: 中文, en: English)
LANGUAGE=zh

# 强制 Mock（不调用真实 LLM）；没有任何 API Key 时后端也会自动回退到 Mock
LLM_USE_MOCK=false

# 默认 LLM（default provider）配置：当某个座位没有专属 provider/mapping 时使用
LLM_MODEL=gpt-4o-mini
LLM_MAX_RETRIES=2

# ============================================================================
# 前端（frontend）
# ============================================================================
# Docker（Nginx 反代 /api）建议保持空字符串：
VITE_API_URL=
# 本地开发（vite dev）可改为：
# VITE_API_URL=http://localhost:8082

# ============================================================================
# 命名 Provider（OPENAI/ANTHROPIC/DEEPSEEK/...）
# ============================================================================
# 规则：
# - 后端会把内置命名 provider 统一转换为小写 key（openai/anthropic/deepseek/...）
# - base_url 留空表示使用 SDK 默认（或你自己的代理/网关默认）
# - *_MAX_RETRIES/_TEMPERATURE/_MAX_TOKENS 留空时会使用代码默认值

# OpenAI（default provider 使用 OPENAI_API_KEY + OPENAI_BASE_URL + LLM_MODEL）
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=2
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=500

# Anthropic（Claude；需要 OpenAI 兼容网关/代理，才能通过 OpenAI SDK 调用）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_MAX_RETRIES=2
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=500

# DeepSeek（OpenAI 兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=500

# Moonshot（Kimi，OpenAI 兼容）
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k
MOONSHOT_MAX_RETRIES=2
MOONSHOT_TEMPERATURE=0.7
MOONSHOT_MAX_TOKENS=500

# Qwen（DashScope OpenAI 兼容）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo
QWEN_MAX_RETRIES=2
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=500

# GLM（智谱 OpenAI 兼容）
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash
GLM_MAX_RETRIES=2
GLM_TEMPERATURE=0.7
GLM_MAX_TOKENS=500

# Doubao（火山方舟 OpenAI 兼容；按需填写 BASE_URL）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODEL=doubao-pro-4k
DOUBAO_MAX_RETRIES=2
DOUBAO_TEMPERATURE=0.7
DOUBAO_MAX_TOKENS=500

# MiniMax（按需填写 BASE_URL）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL=abab6.5s-chat
MINIMAX_MAX_RETRIES=2
MINIMAX_TEMPERATURE=0.7
MINIMAX_MAX_TOKENS=500

# ============================================================================
# 自定义 Provider（AI_PROVIDER_1..9，可选）
# ============================================================================
# 说明：
# - AI_PROVIDER_{i}_NAME 是 provider key（不会自动 lower/upper；请和 mapping 中保持一致）
# - 只要 API_KEY 非空就会启用
AI_PROVIDER_1_NAME=
AI_PROVIDER_1_API_KEY=
AI_PROVIDER_1_BASE_URL=
AI_PROVIDER_1_MODEL=
AI_PROVIDER_1_MAX_RETRIES=2
AI_PROVIDER_1_TEMPERATURE=0.7
AI_PROVIDER_1_MAX_TOKENS=500

AI_PROVIDER_2_NAME=
AI_PROVIDER_2_API_KEY=
AI_PROVIDER_2_BASE_URL=
AI_PROVIDER_2_MODEL=
AI_PROVIDER_2_MAX_RETRIES=2
AI_PROVIDER_2_TEMPERATURE=0.7
AI_PROVIDER_2_MAX_TOKENS=500

# ============================================================================
# 座位到 Provider 的映射（可选）
# ============================================================================
# 配置优先级(从高到低):
# 1) AI_PLAYER_{seat}_PROVIDER - 单独指定provider (最高优先级,覆盖所有其他配置)
# 2) AI_PLAYER_MAPPING - JSON批量映射
# 3) AI_PLAYER_{seat}_API_KEY - 专属配置自动映射到 player_{seat}
# 4) default provider - OPENAI_* 兜底 (最低优先级)
#
# 推荐用法:
# - 大部分玩家使用同一家: 配置 OPENAI_API_KEY 作为兜底
# - 个别玩家用不同家: 配置 AI_PLAYER_{seat}_PROVIDER=anthropic
# - 单个玩家独立配置: 配置 AI_PLAYER_{seat}_API_KEY + MODEL + URL
#
# 配置示例:
# 示例1: 全部使用OpenAI兜底
#   OPENAI_API_KEY=sk-xxx
#   OPENAI_MODEL=gpt-4o-mini
#
# 示例2: 玩家3使用Anthropic,其他用OpenAI
#   OPENAI_API_KEY=sk-xxx
#   ANTHROPIC_API_KEY=sk-ant-xxx
#   AI_PLAYER_3_PROVIDER=anthropic
#
# 示例3: 玩家5使用专属DeepSeek配置
#   AI_PLAYER_5_API_KEY=sk-deepseek-xxx
#   AI_PLAYER_5_BASE_URL=https://api.deepseek.com/v1
#   AI_PLAYER_5_MODEL=deepseek-chat
#
# 示例4: 混合使用
#   OPENAI_API_KEY=sk-xxx                    # 兜底
#   ANTHROPIC_API_KEY=sk-ant-xxx             # 命名provider
#   AI_PLAYER_2_PROVIDER=anthropic           # 玩家2用Anthropic
#   AI_PLAYER_3_API_KEY=sk-deepseek-xxx      # 玩家3专属DeepSeek
#   AI_PLAYER_3_BASE_URL=https://api.deepseek.com/v1
#   AI_PLAYER_MAPPING={"4":"anthropic"}      # 玩家4也用Anthropic

# JSON 批量映射（优先级: 中等）
AI_PLAYER_MAPPING=

# 单独映射到已有命名provider（优先级: 最高）
AI_PLAYER_1_PROVIDER=
AI_PLAYER_2_PROVIDER=
AI_PLAYER_3_PROVIDER=
AI_PLAYER_4_PROVIDER=
AI_PLAYER_5_PROVIDER=
AI_PLAYER_6_PROVIDER=
AI_PLAYER_7_PROVIDER=
AI_PLAYER_8_PROVIDER=
AI_PLAYER_9_PROVIDER=

# ============================================================================
# 每座位独立配置（座位 2-9，可选）
# ============================================================================
# 说明：
# - 配置 AI_PLAYER_{seat}_API_KEY 会自动创建专属 provider: player_{seat}
# - 该玩家会自动映射到 player_{seat}（除非被 AI_PLAYER_{seat}_PROVIDER 覆盖）
# - 如果只配置了 MODEL/URL 而没有 API_KEY,不会创建专属provider
# - 适用场景: 某个玩家需要完全独立的API配置

AI_PLAYER_2_NAME=
AI_PLAYER_2_API_KEY=
AI_PLAYER_2_BASE_URL=
AI_PLAYER_2_MODEL=gpt-4o-mini
AI_PLAYER_2_MAX_RETRIES=2
AI_PLAYER_2_TEMPERATURE=0.7
AI_PLAYER_2_MAX_TOKENS=500

AI_PLAYER_3_NAME=
AI_PLAYER_3_API_KEY=
AI_PLAYER_3_BASE_URL=
AI_PLAYER_3_MODEL=gpt-4o-mini
AI_PLAYER_3_MAX_RETRIES=2
AI_PLAYER_3_TEMPERATURE=0.7
AI_PLAYER_3_MAX_TOKENS=500

AI_PLAYER_4_NAME=
AI_PLAYER_4_API_KEY=
AI_PLAYER_4_BASE_URL=
AI_PLAYER_4_MODEL=gpt-4o-mini
AI_PLAYER_4_MAX_RETRIES=2
AI_PLAYER_4_TEMPERATURE=0.7
AI_PLAYER_4_MAX_TOKENS=500

AI_PLAYER_5_NAME=
AI_PLAYER_5_API_KEY=
AI_PLAYER_5_BASE_URL=
AI_PLAYER_5_MODEL=gpt-4o-mini
AI_PLAYER_5_MAX_RETRIES=2
AI_PLAYER_5_TEMPERATURE=0.7
AI_PLAYER_5_MAX_TOKENS=500

AI_PLAYER_6_NAME=
AI_PLAYER_6_API_KEY=
AI_PLAYER_6_BASE_URL=
AI_PLAYER_6_MODEL=gpt-4o-mini
AI_PLAYER_6_MAX_RETRIES=2
AI_PLAYER_6_TEMPERATURE=0.7
AI_PLAYER_6_MAX_TOKENS=500

AI_PLAYER_7_NAME=
AI_PLAYER_7_API_KEY=
AI_PLAYER_7_BASE_URL=
AI_PLAYER_7_MODEL=gpt-4o-mini
AI_PLAYER_7_MAX_RETRIES=2
AI_PLAYER_7_TEMPERATURE=0.7
AI_PLAYER_7_MAX_TOKENS=500

AI_PLAYER_8_NAME=
AI_PLAYER_8_API_KEY=
AI_PLAYER_8_BASE_URL=
AI_PLAYER_8_MODEL=gpt-4o-mini
AI_PLAYER_8_MAX_RETRIES=2
AI_PLAYER_8_TEMPERATURE=0.7
AI_PLAYER_8_MAX_TOKENS=500

AI_PLAYER_9_NAME=
AI_PLAYER_9_API_KEY=
AI_PLAYER_9_BASE_URL=
AI_PLAYER_9_MODEL=gpt-4o-mini
AI_PLAYER_9_MAX_RETRIES=2
AI_PLAYER_9_TEMPERATURE=0.7
AI_PLAYER_9_MAX_TOKENS=500
