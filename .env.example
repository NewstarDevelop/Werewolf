# ============================================
# 狼人杀 AI 游戏 - Docker 环境配置
# ============================================
# 将此文件复制为 .env 并填入您的 API 密钥
# 使用方法: cp .env.example .env

# ==========================================
# 应用程序设置
# ==========================================
DEBUG=false                # 调试模式（true/false）
LOG_LEVEL=INFO            # 日志级别（DEBUG/INFO/WARNING/ERROR）
LLM_USE_MOCK=false        # 是否使用模拟模式（测试用，不调用真实 API）

# ==========================================
# 默认 LLM 配置（兜底配置）
# ==========================================
# 当某个玩家没有指定专属配置时，将使用此默认配置
OPENAI_API_KEY=your-openai-api-key-here     # 默认 API 密钥
OPENAI_BASE_URL=                            # 默认 API 地址（留空使用官方地址）
LLM_MODEL=gpt-4o-mini                       # 默认模型
LLM_MAX_RETRIES=2                           # 默认重试次数

# ==========================================
# 每个 AI 玩家的独立配置
# ==========================================
# 座位 1 是人类玩家，座位 2-9 是 AI 玩家
# 每个 AI 可以配置不同的模型商、API 密钥和模型

# --- 玩家 2 配置 ---
AI_PLAYER_2_NAME=OpenAI                     # 提供商名称（用于日志显示）
AI_PLAYER_2_API_KEY=                        # API 密钥
AI_PLAYER_2_BASE_URL=                       # API 地址（留空使用官方地址）
AI_PLAYER_2_MODEL=gpt-4o-mini               # 模型名称
AI_PLAYER_2_TEMPERATURE=0.7                 # 温度参数（0-2，越高越随机）
AI_PLAYER_2_MAX_RETRIES=2                   # 重试次数

# --- 玩家 3 配置 ---
AI_PLAYER_3_NAME=DeepSeek                   # 提供商名称
AI_PLAYER_3_API_KEY=                        # API 密钥
AI_PLAYER_3_BASE_URL=https://api.deepseek.com/v1
AI_PLAYER_3_MODEL=deepseek-chat
AI_PLAYER_3_TEMPERATURE=0.7
AI_PLAYER_3_MAX_RETRIES=2

# --- 玩家 4 配置 ---
AI_PLAYER_4_NAME=Moonshot                   # 提供商名称（月之暗面 Kimi）
AI_PLAYER_4_API_KEY=
AI_PLAYER_4_BASE_URL=https://api.moonshot.cn/v1
AI_PLAYER_4_MODEL=moonshot-v1-8k
AI_PLAYER_4_TEMPERATURE=0.7
AI_PLAYER_4_MAX_RETRIES=2

# --- 玩家 5 配置 ---
AI_PLAYER_5_NAME=Qwen                       # 提供商名称（阿里通义千问）
AI_PLAYER_5_API_KEY=
AI_PLAYER_5_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_PLAYER_5_MODEL=qwen-turbo
AI_PLAYER_5_TEMPERATURE=0.7
AI_PLAYER_5_MAX_RETRIES=2

# --- 玩家 6 配置 ---
AI_PLAYER_6_NAME=GLM                        # 提供商名称（智谱 AI）
AI_PLAYER_6_API_KEY=
AI_PLAYER_6_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_PLAYER_6_MODEL=glm-4-flash
AI_PLAYER_6_TEMPERATURE=0.7
AI_PLAYER_6_MAX_RETRIES=2

# --- 玩家 7 配置 ---
AI_PLAYER_7_NAME=Anthropic                  # 提供商名称（Claude，需要兼容代理）
AI_PLAYER_7_API_KEY=
AI_PLAYER_7_BASE_URL=
AI_PLAYER_7_MODEL=claude-3-haiku-20240307
AI_PLAYER_7_TEMPERATURE=0.7
AI_PLAYER_7_MAX_RETRIES=2

# --- 玩家 8 配置 ---
AI_PLAYER_8_NAME=Doubao                     # 提供商名称（字节跳动豆包）
AI_PLAYER_8_API_KEY=
AI_PLAYER_8_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_PLAYER_8_MODEL=doubao-pro-4k
AI_PLAYER_8_TEMPERATURE=0.7
AI_PLAYER_8_MAX_RETRIES=2

# --- 玩家 9 配置 ---
AI_PLAYER_9_NAME=MiniMax                    # 提供商名称
AI_PLAYER_9_API_KEY=
AI_PLAYER_9_BASE_URL=https://api.minimax.chat/v1
AI_PLAYER_9_MODEL=abab6.5s-chat
AI_PLAYER_9_TEMPERATURE=0.7
AI_PLAYER_9_MAX_RETRIES=2

# ==========================================
# 预设的其他模型商配置（供参考）
# ==========================================
# 您可以将这些配置复制到上面的玩家配置中使用

# --- Google Gemini ---
# NAME=Gemini
# API_KEY=
# BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# MODEL=gemini-2.0-flash-exp
# TEMPERATURE=0.7

# --- Anthropic Claude (官方) ---
# NAME=Claude
# API_KEY=
# BASE_URL=https://api.anthropic.com/v1
# MODEL=claude-3-5-sonnet-20241022
# TEMPERATURE=0.7

# --- OpenRouter (支持多模型) ---
# NAME=OpenRouter
# API_KEY=
# BASE_URL=https://openrouter.ai/api/v1
# MODEL=anthropic/claude-3.5-sonnet
# TEMPERATURE=0.7

# --- 本地 Ollama ---
# NAME=Ollama
# API_KEY=ollama  # 本地不需要真实密钥
# BASE_URL=http://localhost:11434/v1
# MODEL=qwen2.5:7b
# TEMPERATURE=0.7

# --- 自定义 API 中转 ---
# NAME=CustomProxy
# API_KEY=
# BASE_URL=https://your-proxy.com/v1
# MODEL=gpt-4o
# TEMPERATURE=0.7

# ==========================================
# 配置示例
# ==========================================

# 示例 1: 所有玩家使用同一个模型商（最简单）
# 只需要配置默认的 OPENAI_API_KEY，其他玩家配置留空即可

# 示例 2: 每个玩家使用不同的模型商（多样性测试）
# 将每个 AI_PLAYER_X_API_KEY 都填上，让不同模型互相对战

# 示例 3: 部分玩家使用专属配置，其他使用默认
# 只配置几个玩家的 AI_PLAYER_X_* 参数，其他玩家会使用默认配置

# 示例 4: 同一个模型商的不同模型对战
# AI_PLAYER_2_MODEL=gpt-4o
# AI_PLAYER_3_MODEL=gpt-4o-mini
# AI_PLAYER_4_MODEL=gpt-3.5-turbo
# 让它们使用相同的 API_KEY，但模型不同

# 示例 5: 模拟模式（测试用，不消耗 API）
# LLM_USE_MOCK=true
# 系统会自动生成随机发言，不调用任何 API

# ==========================================
# 注意事项
# ==========================================
# 1. 所有模型商都需要使用 OpenAI 兼容的 API 格式
# 2. 如果某个玩家的 API_KEY 为空，将使用默认配置
# 3. 不要在此文件中填写真实密钥，请复制为 .env 后再填写
# 4. BASE_URL 为空时，系统会使用 OpenAI 官方地址
# 5. TEMPERATURE 范围通常是 0-2，建议 0.6-0.9
# 6. MAX_RETRIES 建议设置为 2-4，避免 API 超时
